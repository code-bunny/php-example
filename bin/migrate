#!/usr/bin/env php
<?php

require_once __DIR__ . '/../config/database.php';

// Ensure migrations tracking table exists
$pdo->exec("CREATE TABLE IF NOT EXISTS migrations (
    id INT AUTO_INCREMENT PRIMARY KEY,
    migration VARCHAR(255) NOT NULL,
    run_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
)");

$ran = $pdo->query("SELECT migration FROM migrations")->fetchAll(PDO::FETCH_COLUMN);

$files = glob(__DIR__ . '/../db/migrations/*.php');
sort($files);

$pending = array_filter($files, fn($f) => !in_array(basename($f), $ran));

if (empty($pending)) {
    echo "Nothing to migrate.\n";
} else {
    foreach ($pending as $file) {
        $name = basename($file);
        echo "Running: $name ... ";
        $migration = require $file;
        $migration($pdo);
        $pdo->prepare("INSERT INTO migrations (migration) VALUES (?)")->execute([$name]);
        echo "done\n";
    }
}

// ── Schema snapshot ───────────────────────────────────────────────────────────

$lastMigration = $pdo->query(
    "SELECT migration FROM migrations ORDER BY run_at DESC, id DESC LIMIT 1"
)->fetchColumn();

$tables = $pdo->query(
    "SELECT TABLE_NAME
     FROM INFORMATION_SCHEMA.TABLES
     WHERE TABLE_SCHEMA = DATABASE()
       AND TABLE_NAME   != 'migrations'
     ORDER BY TABLE_NAME"
)->fetchAll(PDO::FETCH_COLUMN);

$schema = [];
foreach ($tables as $table) {
    $stmt = $pdo->prepare(
        "SELECT COLUMN_NAME, COLUMN_TYPE, IS_NULLABLE, COLUMN_DEFAULT, EXTRA
         FROM INFORMATION_SCHEMA.COLUMNS
         WHERE TABLE_SCHEMA = DATABASE()
           AND TABLE_NAME   = ?
         ORDER BY ORDINAL_POSITION"
    );
    $stmt->execute([$table]);
    foreach ($stmt->fetchAll(PDO::FETCH_ASSOC) as $col) {
        $schema[$table][$col['COLUMN_NAME']] = [
            'type'     => $col['COLUMN_TYPE'],
            'nullable' => $col['IS_NULLABLE'] === 'YES',
            'default'  => $col['COLUMN_DEFAULT'],
            'extra'    => $col['EXTRA'] ?: null,
        ];
    }
}

$appEnv = $_ENV['APP_ENV'] ?? getenv('APP_ENV') ?: 'development';

$out   = [];
$out[] = "<?php\n";
$out[] = "\n";
$out[] = "// Auto-generated by bin/migrate — do not edit manually.\n";
$out[] = "// Generated:      " . date('Y-m-d H:i:s') . " ({$appEnv})\n";
if ($lastMigration) {
    $out[] = "// Last migration: {$lastMigration}\n";
}
$out[] = "\n";
$out[] = "return [\n";

foreach ($schema as $table => $columns) {
    $out[] = "\n";
    $out[] = "    '{$table}' => [\n";

    $pad = max(array_map('strlen', array_keys($columns)));

    foreach ($columns as $col => $meta) {
        $key      = str_pad("'{$col}'", $pad + 2);
        $type     = "'" . $meta['type'] . "'";
        $nullable = $meta['nullable'] ? 'true ' : 'false';
        $default  = $meta['default'] !== null ? "'" . $meta['default'] . "'" : 'null ';
        $extra    = $meta['extra']   !== null ? "'" . $meta['extra']   . "'" : 'null ';
        $out[]    = "        {$key} => ['type' => {$type}, 'nullable' => {$nullable}, 'default' => {$default}, 'extra' => {$extra}],\n";
    }

    $out[] = "    ],\n";
}

$out[] = "\n";
$out[] = "];\n";

$schemaPath = __DIR__ . '/../db/schema.php';
file_put_contents($schemaPath, implode('', $out));
echo "Schema written to db/schema.php\n";
