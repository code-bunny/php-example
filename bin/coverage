#!/usr/bin/env bash
set -e

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
TMP="$(php -r 'echo sys_get_temp_dir();')"

# ── Clear old coverage data ───────────────────────────────────────────────────
rm -f "$TMP"/phpcov_*.json
rm -rf "$ROOT/coverage"

# ── Run all tests with coverage enabled ──────────────────────────────────────
APP_URL=http://localhost:8001 XDEBUG_MODE=coverage "$ROOT/vendor/bin/phpunit" "$@"

# ── Merge all coverage JSON files and generate the HTML report ────────────────
echo ""
echo "Generating coverage report..."
php "$ROOT/bin/merge-coverage"

open "$ROOT/coverage/index.html" 2>/dev/null || true
