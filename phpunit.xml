<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         colors="true">
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/unit</directory>
        </testsuite>
        <testsuite name="API">
            <directory>tests/api</directory>
        </testsuite>
        <testsuite name="Pages">
            <directory>tests/pages</directory>
        </testsuite>
    </testsuites>

    <source>
        <!--
            Coverage is measured by unit tests (tests/unit/) which load app code
            directly in-process. Request tests (api/, pages/) make real HTTP calls
            to the running server — a separate process — so that code can't be
            instrumented here. Scope coverage to what unit tests can actually reach.
        -->
        <include>
            <directory>models</directory>
            <directory>helpers</directory>
        </include>
    </source>
</phpunit>
