# Copy this file to .env and fill in your values.
# .env is never committed to version control.

APP_ENV=development  # set to "production" to hide errors and enable error logging

DB_HOST=127.0.0.1
DB_NAME=mydb
DB_USER=user
DB_PASS=pass

ADMIN_USER=admin
ADMIN_PASS=secret  # change this before deploying
